const _MathUtilsFinalizer: FinalizationRegistry<number> | null =
  typeof FinalizationRegistry === "undefined"
    ? null
    : new FinalizationRegistry<number>((handle) => {
        _exports.boltffi_math_utils_free(handle);
      });

export class MathUtils {
  private _handle: number;
  private _disposed: boolean;

  private constructor(handle: number) {
    this._handle = handle;
    this._disposed = false;
    _MathUtilsFinalizer?.register(this, handle, this);
  }

  static _fromHandle(handle: number): MathUtils {
    if (handle === 0) {
      throw new Error("MathUtils received a null handle");
    }
    return new MathUtils(handle);
  }

  [Symbol.dispose](): void {
    this.dispose();
  }

  dispose(): void {
    if (this._disposed) {
      return;
    }
    this._disposed = true;
    _MathUtilsFinalizer?.unregister(this);
    _exports.boltffi_math_utils_free(this._handle);
    this._handle = 0;
  }

  /**
   * moves this rust-owned handle into the ffi callee; this wrapper must not be used afterward (mirrors swift `takeHandle()`).
   */
  takeHandle(): number {
    if (this._disposed) {
      throw new Error("MathUtils has been disposed");
    }
    if (this._handle === 0) {
      throw new Error("MathUtils received a null handle");
    }
    this._disposed = true;
    _MathUtilsFinalizer?.unregister(this);
    const h = this._handle;
    this._handle = 0;
    return h;
  }

  private _assertNotDisposed(): void {
    if (this._disposed) {
      throw new Error("MathUtils has been disposed");
    }
  }

  static add(a: number, b: number): number {
    return _exports.boltffi_math_utils_add(a, b);
  }
}
