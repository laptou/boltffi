const _DatabaseFinalizer: FinalizationRegistry<number> | null =
  typeof FinalizationRegistry === "undefined"
    ? null
    : new FinalizationRegistry<number>((handle) => {
        _exports.boltffi_database_free(handle);
      });

export class Database {
  private _handle: number;
  private _disposed: boolean;

  private constructor(handle: number) {
    this._handle = handle;
    this._disposed = false;
    _DatabaseFinalizer?.register(this, handle, this);
  }

  static _fromHandle(handle: number): Database {
    if (handle === 0) {
      throw new Error("Database received a null handle");
    }
    return new Database(handle);
  }

  [Symbol.dispose](): void {
    this.dispose();
  }

  dispose(): void {
    if (this._disposed) {
      return;
    }
    this._disposed = true;
    _DatabaseFinalizer?.unregister(this);
    _exports.boltffi_database_free(this._handle);
    this._handle = 0;
  }

  /**
   * moves this rust-owned handle into the ffi callee; this wrapper must not be used afterward (mirrors swift `takeHandle()`).
   */
  takeHandle(): number {
    if (this._disposed) {
      throw new Error("Database has been disposed");
    }
    if (this._handle === 0) {
      throw new Error("Database received a null handle");
    }
    this._disposed = true;
    _DatabaseFinalizer?.unregister(this);
    const h = this._handle;
    this._handle = 0;
    return h;
  }

  private _assertNotDisposed(): void {
    if (this._disposed) {
      throw new Error("Database has been disposed");
    }
  }

  async query(sql: string): Promise<QueryResult> {
    this._assertNotDisposed();
    const sql_alloc = _module.allocString(sql);
    try {
      const handle = _exports.boltffi_database_query(this._handle, sql_alloc.ptr, sql_alloc.len);
      const awaitedHandle = await _module.asyncManager.pollAsync(
        handle,
        (futureHandle: number) => _exports.boltffi_database_query_poll_sync(futureHandle),
        (futureHandle: number) => _exports.boltffi_database_query_panic_message(futureHandle),
        (futureHandle: number) => _exports.boltffi_database_query_free(futureHandle)
      );
      const outPtr = _module.allocBufDescriptor();
      let completeCompleted = false;
      try {
        _exports.boltffi_database_query_complete(outPtr, awaitedHandle, 0);
        completeCompleted = true;
        const reader = _module.readerFromBuf(outPtr);
        const result = QueryResultCodec.decode(reader);
        return result;
      } finally {
        if (completeCompleted) {
          _module.freeBuf(outPtr);
        } else {
          _module.freeBufDescriptor(outPtr);
        }
        _exports.boltffi_database_query_free(awaitedHandle);
      }
    } finally {
      _module.freeAlloc(sql_alloc);
    }
  }
}
