      throw new Error("Counter has been disposed");
    }
    if (this._handle === 0) {
      throw new Error("Counter received a null handle");
    }
    this._disposed = true;
    _CounterFinalizer?.unregister(this);
    const h = this._handle;
    this._handle = 0;
    return h;
  }

  private _assertNotDisposed(): void {
    if (this._disposed) {
      throw new Error("Counter has been disposed");
    }
  }

