    const handle = _exports.boltffi_counter_next_value(this._handle);
    const awaitedHandle = await _module.asyncManager.pollAsync(
      handle,
      (futureHandle: number) => _exports.boltffi_counter_next_value_poll_sync(futureHandle),
      (futureHandle: number) => _exports.boltffi_counter_next_value_panic_message(futureHandle),
      (futureHandle: number) => _exports.boltffi_counter_next_value_free(futureHandle)
    );
    const outPtr = _module.allocBufDescriptor();
    let completeCompleted = false;
    try {
      _exports.boltffi_counter_next_value_complete(outPtr, awaitedHandle, 0);
      completeCompleted = true;
      const reader = _module.readerFromBuf(outPtr);
