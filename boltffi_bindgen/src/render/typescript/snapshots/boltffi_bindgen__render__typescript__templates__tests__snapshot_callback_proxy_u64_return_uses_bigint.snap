const _stream_source_release = (handle: number): void => {
  const handle_key = _callback_handle_key(handle);
  const currentCount = _stream_source_ref_counts.get(handle_key);
  if (currentCount === undefined) {
    throw new Error(`Cannot free unknown callback handle ${handle_key} in StreamSource registry`);
