{
  "name": "@boltffi/runtime",
  "version": "0.24.0",
  "description": "WASM runtime for BoltFFI generated TypeScript bindings",
  "author": "Ali A. Hilal <me@alihilal.com>",
  "homepage": "https://boltffi.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/boltffi/boltffi",
    "directory": "runtime/typescript"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "ffi",
    "wasm",
    "webassembly",
    "boltffi",
    "rust",
    "wasm-bindgen"
  ],
  "license": "MIT"
}
